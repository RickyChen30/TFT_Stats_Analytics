# Copy to .env and adjust. docker-compose reads these.

# Riot Games developer API key. Leave as "synthetic" to run the whole pipeline
# on generated match data with no external dependency.
RIOT_API_KEY=synthetic

# Regions and tiers to ingest (comma-separated).
REGIONS=NA,EUW
TIERS=IRON,GOLD,PLATINUM,DIAMOND,MASTER,CHALLENGER

# Set 17 patches to spread synthetic data across, oldest -> newest (the last is
# the current patch). Navigable from the dashboard's Patch filter.
PATCHES=16.10,16.11,16.12

# Base URL the dashboard uses to reach the API (baked in at build time).
VITE_API_BASE=http://localhost:8000

# Broker log retention: max records kept per partition (older trimmed). Keeps
# the append-only logs bounded so continuous ingestion does not fill the disk.
BROKER_MAX_RECORDS=10000

# ---- Security ----
# Grafana admin password (required — compose refuses to start without it).
GRAFANA_ADMIN_PASSWORD=change-me
# Set "false" to require login for Grafana (default allows read-only anonymous
# Viewer access; it is never Admin).
GRAFANA_ANON_ENABLED=true

# API CORS allow-list (comma-separated origins permitted to call the API).
ALLOWED_ORIGINS=http://localhost:8080

# API rate limits. Per-IP requests/min across all endpoints; a tighter bucket
# for the Riot-backed player endpoints; and a global daily cap that protects the
# shared Riot key budget from exhaustion.
RATE_LIMIT_PER_MIN=120
PLAYER_RATE_PER_MIN=12
RIOT_DAILY_CAP=20000
